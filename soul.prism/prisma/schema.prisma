generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  workspaces        UserWorkspace[]
  collections       Collection[]
  requests          Request[]
  graphqlRequests   GraphQLRequest[]
  grpcRequests      GRPCRequest[]
}


model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users        UserWorkspace[]
  collections  Collection[]
  environments Environment[]

  workflows Workflow[]
}

model UserWorkspace {
  id          String        @id @default(uuid())
  userId      String
  workspaceId String
  role        WorkspaceRole
  joinedAt    DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

enum WorkspaceRole {
  admin
  editor
  viewer
}


enum WorkflowStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum WorkflowStepStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}


model Workflow {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  description String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  steps WorkflowStep[]
  runs  WorkflowRun[]

  @@index([workspaceId])
}

model WorkflowStep {
  id          String @id @default(uuid())
  workflowId  String
  requestId   String
  stepOrder   Int
  retryCount  Int     @default(0)
  timeoutMs   Int?
  condition   String?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  runs WorkflowRunStep[]

  @@index([workflowId])
}



model WorkflowRun {
  id          String         @id @default(uuid())
  workflowId  String
  status      WorkflowStatus @default(PENDING)
  startedAt   DateTime?
  endedAt     DateTime?
  triggeredBy String
  createdAt   DateTime       @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  steps WorkflowRunStep[]

  @@index([workflowId])
}



model WorkflowRunStep {
  id            String             @id @default(uuid())
  workflowRunId String
  workflowStepId String
  executionId   String?
  status        WorkflowStepStatus @default(PENDING)
  startedAt     DateTime?
  endedAt       DateTime?
  durationMs    Int?

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  workflowStep WorkflowStep @relation(fields: [workflowStepId], references: [id], onDelete: Cascade)

  @@index([workflowRunId])
}


model Collection {
  id          String   @id @default(uuid())
  name        String
  workspaceId String
  createdById String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  requests  Request[]
  graphqlRequests GraphQLRequest[]
  grpcRequests    GRPCRequest[]
}

model Request {
  id           String   @id @default(uuid())
  name         String
  method       HttpMethod
  url          String
  headers      Json?
  body         String?
  collectionId String
  createdById  String
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdBy  User       @relation(fields: [createdById], references: [id], onDelete: Cascade)

  executions Execution[]
}

model GraphQLRequest {
  id            String   @id @default(uuid())
  name          String
  url           String
  query         String
  variables     String?  @db.Text
  operationName String?
  headers       Json?
  collectionId  String
  createdById   String
  createdAt     DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdBy  User       @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model GRPCRequest {
  id           String   @id @default(uuid())
  name         String
  serverAddress String
  service      String
  method       String
  protoFile    String   @db.Text
  metadata     Json?
  useTls       Boolean  @default(false)
  body         String?  @db.Text
  collectionId String
  createdById  String
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdBy  User       @relation(fields: [createdById], references: [id], onDelete: Cascade)
}


enum HttpMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
}

model Environment {
  id          String   @id @default(uuid())
  name        String
  variables   Json
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Execution {
  id          String   @id @default(uuid())
  requestId   String?
  traceId     String
  statusCode  Int?
  latencyMs   Int?
  executedAt  DateTime @default(now())

  request Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)
}


model Span {
  id            String   @id @default(uuid())
  traceId       String
  spanId        String
  parentSpanId String?
  operation     String
  serviceName   String
  startTime     BigInt
  duration      BigInt
  status        String?
  tags          Json?
  createdAt     DateTime @default(now())

  @@unique([traceId, spanId])
}
